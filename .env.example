# ════════════════════════════════════════════════════════════════
#  MedAssist AI — Environment Variables
#  Copy to .env and fill in all required values.
#  Never commit .env to git.
# ════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=medassist_db
POSTGRES_USER=medassist
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5432

# ── Backend (FastAPI) ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_run_python_secrets_token_hex_32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=production

# JSON array of allowed origins (no trailing slash)
ALLOWED_ORIGINS=["https://medassist-ai.com","https://www.medassist-ai.com"]

# For local dev / Docker:
# ALLOWED_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000","http://localhost:5173"]

# ── Frontend (Vite) ───────────────────────────────────────────
# In Docker / production: use relative path (nginx proxies /api → backend)
VITE_API_BASE_URL=/api
# In local dev without Docker:
# VITE_API_BASE_URL=http://localhost:8000

# ── Domain & SSL ──────────────────────────────────────────────
DOMAIN=medassist-ai.com
SSL_EMAIL=admin@medassist.co.ke

# ── Ports (override if defaults conflict) ─────────────────────
BACKEND_PORT=8000
# POSTGRES_PORT=5432   # already set above

# ── M-Pesa Daraja API (Phase 2 — leave blank for demo) ────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENVIRONMENT=sandbox
# MPESA_ENVIRONMENT=production  # for live transactions

# ── AWS (production deployment — not needed for Docker demo) ──
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# RDS connection string (replaces DATABASE_URL for EC2 deployments)
# AWS_RDS_URL=postgresql://medassist:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/medassist_db

# ── Vercel (CI/CD — set in GitHub Actions secrets, not here) ──
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ── SendGrid / Email (future — leave blank for demo) ──────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@medassist.co.ke

# ── Sentry (error monitoring — optional) ──────────────────────
SENTRY_DSN=
