# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/medassist_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── AWS S3 (or MinIO for local dev) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
S3_BUCKET_NAME=medassist-uploads
# Leave blank for real S3; set to http://localhost:9000 for MinIO
S3_ENDPOINT_URL=

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@medassist.co.ke
EMAIL_FROM_NAME=MedAssist AI

# ─── Africa's Talking (SMS) ───────────────────────────────────────────────────
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=MedAssist

# ─── M-Pesa Daraja API ────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://api.medassist.co.ke/v1/payments/mpesa/callback

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Security ─────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
PASSWORD_MIN_LENGTH=8

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development
